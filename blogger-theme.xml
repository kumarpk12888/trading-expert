<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false' b:defaultwidgetversion='2' b:layoutsVersion='3' b:responsive='true' b:templateUrl='indie.xml' b:templateVersion='1.3.0' expr:dir='data:blog.languageDirection' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>

<head>
  <meta content='width=device-width, initial-scale=1' name='viewport'/>
  <b:include data='blog' name='all-head-content'/>
  <title><data:blog.pageTitle/></title>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');

    :root {
      --bg: #0b0e14;
      --surface: #131820;
      --border: #1e2530;
      --green: #00c896;
      --red: #ff4d6d;
      --gold: #f5a623;
      --text: #e2e8f0;
      --muted: #64748b;
      --accent: #3b82f6;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 15px;
      line-height: 1.7;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { color: var(--green); }

    /* NAV */
    .navbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .blog-title-link {
      font-family: 'JetBrains Mono', monospace;
      font-size: 18px;
      font-weight: 700;
      color: var(--green) !important;
    }

    .blog-title-link:hover { color: var(--green) !important; }

    .nav-pages {
      display: flex;
      gap: 20px;
      list-style: none;
    }

    .nav-pages a {
      color: var(--muted);
      font-size: 13px;
      font-weight: 500;
    }

    .nav-pages a:hover { color: var(--text); }

    /* TICKER */
    .ticker-wrap {
      background: #0d1117;
      border-bottom: 1px solid var(--border);
    }

    /* HERO BANNER */
    .hero-banner {
      background: linear-gradient(135deg, #131820 0%, #0b0e14 100%);
      border-bottom: 1px solid var(--border);
      padding: 36px 20px 28px;
      text-align: center;
    }

    .hero-badge {
      display: inline-block;
      background: rgba(0,200,150,0.1);
      border: 1px solid rgba(0,200,150,0.3);
      color: var(--green);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 20px;
      margin-bottom: 14px;
    }

    .hero-banner h1 {
      font-size: 26px;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--text);
    }

    .hero-banner h1 span { color: var(--green); }

    .hero-banner p {
      color: var(--muted);
      font-size: 14px;
      max-width: 500px;
      margin: 0 auto;
    }

    /* LAYOUT */
    .main-wrap {
      max-width: 960px;
      margin: 0 auto;
      padding: 24px 16px;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 24px;
    }

    /* POSTS */
    .post-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 22px;
      margin-bottom: 18px;
      transition: border-color 0.2s;
    }

    .post-card:hover { border-color: var(--accent); }

    .post-label {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 4px;
      margin-bottom: 10px;
      background: rgba(0,200,150,0.15);
      color: var(--green);
    }

    .post-card h2 {
      font-size: 17px;
      font-weight: 700;
      margin-bottom: 8px;
      line-height: 1.3;
    }

    .post-card h2 a {
      color: var(--text) !important;
    }

    .post-card h2 a:hover { color: var(--green) !important; }

    .post-snippet {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 14px;
    }

    .post-meta {
      display: flex;
      gap: 14px;
      font-size: 11px;
      color: var(--muted);
      border-top: 1px solid var(--border);
      padding-top: 10px;
    }

    .read-more {
      display: inline-block;
      background: rgba(59,130,246,0.1);
      border: 1px solid rgba(59,130,246,0.3);
      color: var(--accent);
      padding: 6px 14px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      margin-top: 10px;
    }

    .read-more:hover {
      background: rgba(59,130,246,0.2);
      color: var(--accent);
    }

    /* FULL POST PAGE */
    .post-body {
      font-size: 15px;
      line-height: 1.8;
      color: #c8d3e0;
    }

    .post-body h2, .post-body h3 {
      color: var(--green);
      margin: 24px 0 10px;
      font-size: 17px;
    }

    .post-body p { margin-bottom: 14px; }

    .post-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
    }

    .post-body table td, .post-body table th {
      border: 1px solid var(--border);
      padding: 8px 12px;
    }

    .post-body table th {
      background: var(--surface);
      color: var(--green);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .post-body table tr:nth-child(even) td {
      background: rgba(255,255,255,0.02);
    }

    .disclaimer-box {
      background: rgba(255,77,109,0.05);
      border: 1px solid rgba(255,77,109,0.2);
      border-radius: 8px;
      padding: 14px;
      font-size: 12px;
      color: var(--muted);
      margin: 20px 0;
    }

    .disclaimer-box strong { color: var(--red); }

    /* SIDEBAR */
    .sidebar-widget {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 18px;
      margin-bottom: 18px;
    }

    .sidebar-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 14px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    /* AD ZONE */
    .ad-zone {
      background: var(--surface);
      border: 1px dashed var(--border);
      border-radius: 8px;
      padding: 16px;
      text-align: center;
      margin-bottom: 18px;
      color: var(--muted);
      font-size: 11px;
      min-height: 100px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* FOOTER */
    .site-footer {
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 28px 20px 20px;
      text-align: center;
      margin-top: 40px;
    }

    .footer-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .footer-links a {
      color: var(--muted);
      font-size: 13px;
    }

    .footer-links a:hover { color: var(--text); }

    .footer-copy {
      font-size: 12px;
      color: var(--muted);
    }

    /* PAGINATION */
    .blog-pager {
      display: flex;
      justify-content: space-between;
      margin: 20px 0;
    }

    .blog-pager a {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 8px 16px;
      border-radius: 6px;
      font-size: 13px;
    }

    .blog-pager a:hover { border-color: var(--accent); }

    @media (max-width: 700px) {
      .main-wrap { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .hero-banner h1 { font-size: 20px; }
      .navbar { flex-direction: column; gap: 10px; }
    }
  </style>
</head>

<body>

<!-- NAVBAR -->
<div class='navbar'>
  <a class='blog-title-link' expr:href='data:blog.homepageUrl'>▲ <data:blog.title/></a>
  <b:section class='nav-pages' id='navpages' maxwidgets='1' showaddelement='yes'>
    <b:widget id='PageList1' locked='false' title='Pages' type='PageList' version='2'>
      <b:widget-settings>
        <b:widget-setting name='showPlaceholder'>false</b:widget-setting>
        <b:widget-setting name='style'>tabsTop</b:widget-setting>
      </b:widget-settings>
    </b:widget>
  </b:section>
</div>

<!-- TICKER -->
<div class='ticker-wrap'>
  <div class='tradingview-widget-container'>
    <div class='tradingview-widget-container__widget'></div>
    <script async='' src='https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js' type='text/javascript'>
    {
      &quot;symbols&quot;: [
        {&quot;proName&quot;: &quot;BSE:SENSEX&quot;, &quot;title&quot;: &quot;Sensex&quot;},
        {&quot;proName&quot;: &quot;NSE:NIFTY&quot;, &quot;title&quot;: &quot;Nifty 50&quot;},
        {&quot;proName&quot;: &quot;NSE:BANKNIFTY&quot;, &quot;title&quot;: &quot;Bank Nifty&quot;},
        {&quot;proName&quot;: &quot;NSE:INDIAVIX&quot;, &quot;title&quot;: &quot;India VIX&quot;},
        {&quot;proName&quot;: &quot;NSE:MIDCPNIFTY&quot;, &quot;title&quot;: &quot;Midcap Nifty&quot;},
        {&quot;proName&quot;: &quot;NSE:CNXIT&quot;, &quot;title&quot;: &quot;Nifty IT&quot;}
      ],
      &quot;showSymbolLogo&quot;: false,
      &quot;isTransparent&quot;: true,
      &quot;displayMode&quot;: &quot;adaptive&quot;,
      &quot;colorTheme&quot;: &quot;dark&quot;,
      &quot;locale&quot;: &quot;en&quot;
    }
    </script>
  </div>
</div>

<!-- HERO -->
<b:if cond='data:blog.pageType == &quot;index&quot;'>
<div class='hero-banner'>
  <div class='hero-badge'>NSE · BSE · India VIX</div>
  <h1>Smart Calls for <span>Indian Markets</span></h1>
  <p>Daily Nifty 50, Sensex &amp; India VIX analysis with intraday trade setups for active NSE/BSE traders.</p>
</div>
</b:if>

<!-- MAIN CONTENT -->
<div class='main-wrap'>

  <!-- LEFT: POSTS -->
  <div class='main-col'>

    <!-- AD TOP -->
    <div class='ad-zone'>
      <!-- AdSense Top Ad -->
      <ins class='adsbygoogle'
           style='display:block'
           data-ad-client='ca-pub-XXXXXXXXXXXXXXXX'
           data-ad-slot='XXXXXXXXXX'
           data-ad-format='auto'
           data-full-width-responsive='true'></ins>
    </div>

    <b:section id='main' maxwidgets='1' showaddelement='no'>
      <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='2'>
        <b:widget-settings>
          <b:widget-setting name='showShareButtons'>false</b:widget-setting>
          <b:widget-setting name='showAuthorProfile'>false</b:widget-setting>
        </b:widget-settings>

        <b:includable id='main'>
          <b:loop values='data:posts' var='post'>

            <b:if cond='data:blog.pageType == &quot;index&quot;'>
              <!-- POST CARD (Homepage) -->
              <div class='post-card'>
                <span class='post-label'>Trading Analysis</span>
                <h2><a expr:href='data:post.url'><data:post.title/></a></h2>
                <div class='post-snippet'>
                  <data:post.snippet/>
                </div>
                <div class='post-meta'>
                  <span>📅 <data:post.dateHeader/></span>
                  <span>✍️ <data:post.author/></span>
                </div>
                <a class='read-more' expr:href='data:post.url'>Read Analysis →</a>
              </div>

            <b:else/>
              <!-- FULL POST PAGE -->
              <div class='post-card'>
                <h1 style='font-size:22px; font-weight:700; margin-bottom:8px;'><data:post.title/></h1>
                <div class='post-meta' style='margin-bottom:20px;'>
                  <span>📅 <data:post.dateHeader/></span>
                  <span>✍️ <data:post.author/></span>
                </div>

                <!-- Mid Ad -->
                <div class='ad-zone' style='margin-bottom:20px;'>
                  <ins class='adsbygoogle'
                       style='display:block'
                       data-ad-client='ca-pub-XXXXXXXXXXXXXXXX'
                       data-ad-slot='XXXXXXXXXX'
                       data-ad-format='auto'></ins>
                </div>

                <div class='post-body'>
                  <data:post.body/>
                </div>

                <div class='disclaimer-box'>
                  <strong>⚠️ Disclaimer:</strong> This analysis is for educational purposes only. Not financial advice. Consult a SEBI-registered advisor before trading. Trade at your own risk.
                </div>

                <!-- Bottom Ad -->
                <div class='ad-zone'>
                  <ins class='adsbygoogle'
                       style='display:block'
                       data-ad-client='ca-pub-XXXXXXXXXXXXXXXX'
                       data-ad-slot='XXXXXXXXXX'
                       data-ad-format='auto'></ins>
                </div>
              </div>
            </b:if>

          </b:loop>

          <!-- PAGINATION -->
          <div class='blog-pager'>
            <b:if cond='data:newerPageUrl'>
              <a expr:href='data:newerPageUrl'>← Newer Posts</a>
            </b:if>
            <b:if cond='data:olderPageUrl'>
              <a expr:href='data:olderPageUrl'>Older Posts →</a>
            </b:if>
          </div>

        </b:includable>
      </b:widget>
    </b:section>

  </div>

  <!-- RIGHT: SIDEBAR -->
  <div class='sidebar'>

    <!-- NIFTY CHART -->
    <div class='sidebar-widget'>
      <div class='sidebar-title'>Nifty 50 — Live</div>
      <div class='tradingview-widget-container'>
        <div class='tradingview-widget-container__widget'></div>
        <script async='' src='https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js' type='text/javascript'>
        {
          &quot;symbol&quot;: &quot;NSE:NIFTY&quot;,
          &quot;width&quot;: &quot;100%&quot;,
          &quot;height&quot;: &quot;180&quot;,
          &quot;locale&quot;: &quot;en&quot;,
          &quot;dateRange&quot;: &quot;1D&quot;,
          &quot;colorTheme&quot;: &quot;dark&quot;,
          &quot;isTransparent&quot;: true,
          &quot;autosize&quot;: false,
          &quot;largeChartUrl&quot;: &quot;&quot;
        }
        </script>
      </div>
    </div>

    <!-- SENSEX CHART -->
    <div class='sidebar-widget'>
      <div class='sidebar-title'>Sensex — Live</div>
      <div class='tradingview-widget-container'>
        <div class='tradingview-widget-container__widget'></div>
        <script async='' src='https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js' type='text/javascript'>
        {
          &quot;symbol&quot;: &quot;BSE:SENSEX&quot;,
          &quot;width&quot;: &quot;100%&quot;,
          &quot;height&quot;: &quot;180&quot;,
          &quot;locale&quot;: &quot;en&quot;,
          &quot;dateRange&quot;: &quot;1D&quot;,
          &quot;colorTheme&quot;: &quot;dark&quot;,
          &quot;isTransparent&quot;: true,
          &quot;autosize&quot;: false
        }
        </script>
      </div>
    </div>

    <!-- INDIA VIX -->
    <div class='sidebar-widget'>
      <div class='sidebar-title'>India VIX — Live</div>
      <div class='tradingview-widget-container'>
        <div class='tradingview-widget-container__widget'></div>
        <script async='' src='https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js' type='text/javascript'>
        {
          &quot;symbol&quot;: &quot;NSE:INDIAVIX&quot;,
          &quot;width&quot;: &quot;100%&quot;,
          &quot;height&quot;: &quot;180&quot;,
          &quot;locale&quot;: &quot;en&quot;,
          &quot;dateRange&quot;: &quot;1D&quot;,
          &quot;colorTheme&quot;: &quot;dark&quot;,
          &quot;isTransparent&quot;: true,
          &quot;autosize&quot;: false
        }
        </script>
      </div>
    </div>

    <!-- SIDEBAR AD -->
    <div class='ad-zone'>
      <ins class='adsbygoogle'
           style='display:block'
           data-ad-client='ca-pub-XXXXXXXXXXXXXXXX'
           data-ad-slot='XXXXXXXXXX'
           data-ad-format='auto'></ins>
    </div>

    <!-- ABOUT WIDGET -->
    <div class='sidebar-widget'>
      <div class='sidebar-title'>About</div>
      <p style='font-size:13px; color:var(--muted); line-height:1.6;'>
        Daily Nifty 50, Sensex &amp; India VIX analysis with intraday trade setups for active NSE/BSE traders.
      </p>
      <p style='font-size:11px; color:var(--red); margin-top:10px;'>
        ⚠️ Educational only. Not financial advice.
      </p>
    </div>

  </div>

</div>

<!-- FOOTER -->
<div class='site-footer'>
  <div class='footer-links'>
    <b:section id='footer-pages' maxwidgets='1' showaddelement='yes'>
      <b:widget id='PageList2' locked='false' title='Footer Pages' type='PageList' version='2'/>
    </b:section>
  </div>
  <div class='footer-copy'>
    © 2026 <data:blog.title/> | tradingniftysensexindiavix. All Rights Reserved.<br/>
    <span style='font-size:11px;'>Educational content only. Not financial advice.</span>
  </div>
</div>

<script>
(adsbygoogle = window.adsbygoogle || []).push({});
</script>

</body>
</html>
